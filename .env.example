# =============================================================================
# ECM JIRA Clone — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# MUST NEVER be committed. All values below are placeholders only — no real
# secrets belong in this file. In production, every secret marked (REQUIRED)
# must be set to a strong, unique value or the server refuses to start
# (see server/config.js `validateConfig`).

# --- Runtime ---------------------------------------------------------------
# NODE_ENV=production enables strict secret validation at startup.
NODE_ENV=development
PORT=4000

# --- Client ----------------------------------------------------------------
VITE_API_URL=http://localhost:4000
APP_URL=http://localhost:5173
# Comma-free single origin, or leave unset to allow all in dev.
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) --------------------------------------------------
# (REQUIRED in production)
DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite
# Used by the backend test suites.
TEST_DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite_test

# --- Auth / JWT ------------------------------------------------------------
# (REQUIRED in production) Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Must NOT be left at the dev default 'ecm-jira-dev-secret-change-in-production'.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# --- SMTP / transactional email (optional) ---------------------------------
# Set all three (HOST, USER, PASS) together to enable real delivery;
# otherwise emails are logged to the console.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourcompany.com

# --- OAuth / SSO (optional, config-gated) ----------------------------------
# A provider is enabled only when BOTH its client id and secret are set.
# Endpoints return 501 until then.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:4000
