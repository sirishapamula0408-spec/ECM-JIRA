# =============================================================================
# ECM JIRA Clone — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# MUST NEVER be committed. All values below are placeholders only — no real
# secrets belong in this file. In production, every secret marked (REQUIRED)
# must be set to a strong, unique value or the server refuses to start
# (see server/config.js `validateConfig`).

# --- Runtime ---------------------------------------------------------------
# NODE_ENV=production enables strict secret validation at startup.
NODE_ENV=development
PORT=4000

# --- Client ----------------------------------------------------------------
VITE_API_URL=http://localhost:4000
APP_URL=http://localhost:5173
# Comma-free single origin, or leave unset to allow all in dev.
CORS_ORIGIN=http://localhost:5173

# --- Database (PostgreSQL) --------------------------------------------------
# (REQUIRED in production)
DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite
# Used by the backend test suites.
TEST_DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite_test

# --- Auth / JWT ------------------------------------------------------------
# (REQUIRED in production) Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#   openssl rand -hex 32
# There is NO in-code fallback: the server refuses to start without JWT_SECRET
# (JL-90). Must NOT be left at the dev default
# 'ecm-jira-dev-secret-change-in-production' (JL-102 validateConfig).
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Production deployment (JL-97) -----------------------------------------
# NODE_ENV=production (or SERVE_STATIC=1) makes Express serve the built /dist
# with an SPA fallback, so a single Node container hosts both API and frontend.
# SERVE_STATIC=1

# Automated DB backups (scripts/backup-db.sh)
# BACKUP_DIR=./backups
# RETENTION_DAYS=14

# --- Auth abuse protection (JL-93) -----------------------------------------
# Comma-separated browser origins allowed for CORS. Leave empty for permissive
# (dev). Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ALLOWED_ORIGINS=
# General API rate limiter (defaults: 600 req / 60s per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
# Tighter limiter for /api/auth (default 60 / window)
AUTH_RATE_LIMIT_MAX=60
# Login brute-force lockout (default: 5 failures / 15min → 15min lock)
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=900000

# --- SCIM 2.0 provisioning (JL-130) ----------------------------------------
# Shared bearer token the IdP (Okta/Azure AD) presents on every /scim/v2 request.
SCIM_TOKEN=dev-scim-token-change-me

# --- SMTP / transactional email (optional) ---------------------------------
# Set all three (HOST, USER, PASS) together to enable real delivery;
# otherwise emails are logged to the console.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@yourcompany.com

# --- OAuth / SSO (optional, config-gated) ----------------------------------
# A provider is enabled only when BOTH its client id and secret are set.
# Endpoints return 501 until then.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:4000

# JL-129: Live SSO — OIDC (leave blank to keep SSO endpoints disabled / 501)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4000/api/auth/sso/oidc/callback

# JL-129: Live SSO — SAML 2.0 (leave blank to keep SSO endpoints disabled / 501)
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:4000/api/auth/sso/saml/callback
# Cloud attachment storage (JL-137) — S3-compatible object storage.
# When all of S3_BUCKET, S3_REGION, S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY
# are set, attachments are stored in object storage; otherwise they default to
# local disk (server/uploads). S3_ENDPOINT is optional (for MinIO / non-AWS).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
