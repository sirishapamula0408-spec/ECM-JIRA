# Server
PORT=4000

# Client
VITE_API_URL=http://localhost:4000
APP_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite

# SMTP (for sending invitation emails)
# Set these to enable real email delivery; without them emails log to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com

# JL-129: Live SSO — OIDC (leave blank to keep SSO endpoints disabled / 501)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:4000/api/auth/sso/oidc/callback

# JL-129: Live SSO — SAML 2.0 (leave blank to keep SSO endpoints disabled / 501)
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:4000/api/auth/sso/saml/callback
