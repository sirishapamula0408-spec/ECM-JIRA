# Server
PORT=4000

# Client
VITE_API_URL=http://localhost:4000
APP_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite

# Auth abuse protection (JL-93)
# Comma-separated browser origins allowed for CORS. Leave empty for permissive
# (dev). Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ALLOWED_ORIGINS=
# General API rate limiter (defaults: 600 req / 60s per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=600
# Tighter limiter for /api/auth (default 60 / window)
AUTH_RATE_LIMIT_MAX=60
# Login brute-force lockout (default: 5 failures / 15min → 15min lock)
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=900000

# SMTP (for sending invitation emails)
# Set these to enable real email delivery; without them emails log to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com
