# Server
PORT=4000

# Client
VITE_API_URL=http://localhost:4000
APP_URL=http://localhost:5173

# Database (PostgreSQL) — REQUIRED
DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite

# Test database (used by server integration tests)
TEST_DATABASE_URL=postgresql://jira_lite:jira_lite_dev@localhost:5432/jira_lite_test

# Auth — REQUIRED
# JWT_SECRET signs all session tokens. There is NO in-code fallback: the server
# refuses to start without it. Set a strong random value (32+ bytes), e.g.:
#   openssl rand -hex 32
JWT_SECRET=
# Token lifetime (optional, default 7d)
JWT_EXPIRES_IN=7d

# Production deployment (JL-97)
# NODE_ENV=production (or SERVE_STATIC=1) makes Express serve the built /dist
# with an SPA fallback, so a single Node container hosts both API and frontend.
# SERVE_STATIC=1
# NODE_ENV=production
CORS_ORIGIN=http://localhost:4000

# Automated DB backups (scripts/backup-db.sh)
# BACKUP_DIR=./backups
# RETENTION_DAYS=14

# SMTP (for sending invitation emails)
# Set these to enable real email delivery; without them emails log to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourcompany.com
